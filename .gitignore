# --- Python / uv ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
# uv.lock IS committed (this is an application)

# --- marimo ---
__marimo__/

# --- frozen extracts & exports (COST: never commit pulled data) ---
analyses/**/data/
analyses/**/out/
*.parquet

# --- terraform ---
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/crash.log
terraform/terraform.tfvars

# --- credentials (NEVER commit; we use ADC, no service-account keys) ---
**/service-account*.json
**/credentials*.json
**/*-key.json
application_default_credentials.json

# --- eval telemetry (local; regenerated) ---
evals/runs/

# --- OS ---
.DS_Store

# --- Claude Code (transient git worktrees / scratch) ---
.claude/worktrees/
